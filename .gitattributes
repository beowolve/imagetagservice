# Normalize text files to LF by default across platforms.
* text=auto eol=lf

# Keep Windows script files in CRLF for native tooling compatibility.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets should never be line-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary

# Model weights — binary, never diff/merge
*.pth binary
*.pt binary
*.onnx binary
*.bin binary
